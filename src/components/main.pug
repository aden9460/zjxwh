.content.content-main
	.portfolio-page
		section#card.hero-card
			.card-inner.fade
				header
					img(src=`${main.avatar.link}` width=`${main.avatar.width}` height=`${main.avatar.height}` alt="郑嘉雯头像")
					h1(data-translate="name") #{main.name}
					h2#signature(original-content=`${main.signature}` data-translate="signature") #{main.signature}
					ul.profile-meta
						li 浙江传媒学院
						li 数字媒体与智能传播硕士
						li 浙江杭州
						li 中共党员
						li 本科广告学
					p.hero-summary
						| 关注 AI Agent、内容运营、品牌传播与数字文旅的结合，具备美妆达人投放、私域运营、新媒体账号孵化、多模态影像策划与数据分析经验。

				- const { first , second , third, fourth } = main.ul
				ul.quick-links
					li
						a(href=`${first.href}` aria-label=`${first.text}`)
							i(class=`icon icon-${first.icon}`)
							span(data-translate=`${first.text}`) #{first.text}
					li
						a(href=`${second.href}` aria-label=`${second.text}`)
							i(class=`icon icon-${second.icon}`)
							span(data-translate=`${second.text}`) #{second.text}
					li
						a(href=`${third.href}` aria-label=`${third.text}`)
							i(class=`icon icon-${third.icon}`)
							span(data-translate=`${third.text}`) #{third.text}
					li
						a(href=`${fourth.href}` aria-label=`${fourth.text}` target="_blank")
							i(class=`icon icon-${fourth.icon}`)
							span(data-translate=`${fourth.text}`) #{fourth.text}

		section.section.about-section#about
			.section-heading
				span About
				h2 自我介绍
			p
				| 我擅长把用户洞察、平台数据和内容创意转化为可执行的传播策略，也在尝试用 Qwen、Codex、Claude、Midjourney 等 Agent 工具提升内容生产、达人筛选和投放决策效率。
			.ability-grid
				.ability-card
					h3 内容运营与品牌传播
					p 能将新品卖点、平台机制和用户兴趣转化为达人 Brief、脚本方向和内容种草策略，熟悉抖音、小红书等平台的内容表达方式。
				.ability-card
					h3 数据复盘与投放判断
					p 关注 CTR、CPM、CPE、ROI 等投放指标，能结合达人画像、报价和互动表现进行合作适配度判断与复盘。
				.ability-card
					h3 AI Agent 与数字内容
					p 使用 Qwen、Qwen3-VL、Codex、Claude、Midjourney 等工具辅助达人筛选、内容生产、多模态分析和项目展示搭建。
			.metrics
				.metric
					strong 3.8
					span 研究生平均绩点
				.metric
					strong Top 10%
					span 本硕成绩排名
				.metric
					strong 50+
					span 达人合作促成
				.metric
					strong 30w
					span 小红书内容浏览

		section.section#work
			.section-heading
				span Work Experience
				h2 工作经验与项目实践
			.project-grid
				article.project-card
					a.project-cover(href="assets/projects/detail.html?project=proya")
						img(src="assets/projects/proya/framework-diagram.png" alt="珀莱雅与彩棠达人筛选 Agent 框架图")
					.project-body
						em 抖音内容运营 · 2025.12 - 2026.05
						h3 珀莱雅 / 彩棠 Beauty KOL Intelligence Agent
						p 围绕底妆新品推广，参与从卖点拆解、达人匹配、脚本审核、素材测试到投放复盘的内容运营链路，并将高频达人筛选流程沉淀为 Agent 原型。
						ul
							li 参与修颜乳、青衣气垫、粉底液等新品上市推广。
							li 将产品卖点转化为千川信息流语言与达人沟通 Brief。
							li 每周输出 20+ 达人推荐清单，累计促成 50+ 达人合作。
						.links
							a(href="assets/projects/detail.html?project=proya") 查看完整项目

				article.project-card
					a.project-cover.text-cover(href="assets/projects/detail.html?project=wuchan")
						span 媒介投放
						strong 数据分析 / 达人建联 / 商务谈判
					.project-body
						em 媒介 · 2025.02 - 2025.05
						h3 物产中大云商公司
						p 参与达人筛选、建联、询价和商务谈判，结合粉丝量级、报价、CPM/CPE 等指标评估合作适配度。
						ul
							li 通过 SQL 提取并分析达人投放数据。
							li 输出合作效果分析报告，支持投放策略优化。
							li 维护达人合作数据库，跟进结算对账和合同流程。
						.links
							a(href="assets/projects/detail.html?project=wuchan") 查看完整项目

				article.project-card
					a.project-cover(href="assets/projects/detail.html?project=kuai")
						img(src="assets/projects/kuai/01.png" alt="快美妆项目截图")
					.project-body
						em 私域运营 · 2024.07 - 2024.10
						h3 快美妆科技有限公司
						p 负责达人全链路私域运营，覆盖商务对接、用户维护、直播跟播、社群活动和导粉。
						ul
							li 参与达人选品与合作沟通，推进合作落地。
							li 维护达人私域社群，提升用户活跃和转化。
							li 负责日播跟播与粉丝需求登记。
						.links
							a(href="assets/projects/detail.html?project=kuai") 查看完整项目

				article.project-card
					a.project-cover(href="assets/projects/detail.html?project=suzhou")
						img(src="assets/projects/suzhou-xinchen/01.jpg" alt="苏州新晨传媒项目截图")
					.project-body
						em 新媒体运营 · 2022.12 - 2023.06
						h3 苏州新晨传媒公司
						p 独立负责小红书账号从 0 到 1 孵化，定位亲子旅行与文旅方向，完成选题、拍摄剪辑、发布和复盘。
						ul
							li 发布 30+ 篇旅行攻略类视频内容。
							li 2 个月涨粉 3000，累计浏览量达 30 万。
							li 根据数据反馈持续调整内容策略。
						.links
							a(href="assets/projects/detail.html?project=suzhou") 查看完整项目

				article.project-card
					a.project-cover(href="assets/projects/detail.html?project=digital")
						img(src="assets/projects/digital-culture/01.png" alt="数字文旅项目截图")
					.project-body
						em 数字文旅项目 · 2024.03 - 2025.12
						h3 多模态数字影像 / 诗路文化带资源平台
						p 参与多模态数字影像、诗路文化带资源平台、数字人影像生成方法等项目，将文化研究内容转化为影像脚本、平台数据和可视化展示。
						ul
							li 设计数字影像脚本，参与数字人视觉效果优化与测试。
							li 撰写并发布项目进展推文 3 篇，相关成果获浙江省科学技术进步奖提名。
							li 整理文化遗产库和旅游产品库，为平台提供结构化数据。
						.links
							a(href="assets/projects/detail.html?project=digital") 查看完整项目

				article.project-card
					a.project-cover(href="assets/projects/detail.html?project=popmart")
						img(src="assets/projects/popmart/cover.png" alt="泡泡玛特策划案")
					.project-body
						em 广告策划作品
						h3 泡泡玛特策划案
						p 围绕品牌传播和消费者洞察完成策划案，呈现从策略分析、创意表达，到传播执行的完整广告策划思路。
						.links
							a(href="assets/projects/detail.html?project=popmart") 查看完整项目

		section.section.campus-section
			.section-heading
				span Campus
				h2 在校经历
			.timeline
				.item
					span 2023.10 - 2026.06
					h3 浙江传媒学院 · 数字媒体与智能传播 硕士
					p 研究生平均绩点 3.8，排名位于专业前 10%；研究方向关注数字内容生产、智能传播、数字文旅与多模态影像。
				.item
					span 2023.10 - 2026.06
					h3 班级心理委员
					p 策划心理健康周、心理健康月等活动，负责宣传文案、心理健康资源整理、讲座咨询组织与同学沟通。
				.item
					span 2020.09 - 2022.05
					h3 社团理事会部长
					p 负责社团活动策划、宣传运营、数据分析和团队管理，推动多部门协作完成校园活动，并根据平台数据调整宣传节奏。
				.item
					span 2019.10 - 2020.06
					h3 社会实践社团干事
					p 参与志愿活动招募、公众号推文撰写、活动预算控制、物料准备和现场执行，积累活动统筹与平台运营经验。

		section.section#skills
			.section-heading
				span Skills
				h2 相关技能
			.skill-grid
				.skill-group
					h3 内容与运营
					p 新品卖点拆解、达人 Brief、脚本策划、KOL/KOC 筛选、账号孵化、社群运营和粉丝互动。
				.skill-group
					h3 数据分析
					p SQL、Python 基础、达人资源台账、CTR / CPM / CPE / ROI、投放复盘和合作效果分析。
				.skill-group
					h3 AI 与 Agent
					p Qwen、Qwen3-VL、Codex、Claude、Midjourney，用于达人筛选、内容生产、多模态分析和网页搭建。
				.skill-group
					h3 设计与影像
					p PS、AE、PR、无人机拍摄、短视频剪辑、信息流视频编剪和宣传物料设计。
				.skill-group
					h3 数字人与网页
					p iClone、Character Creator、Dreamweaver、基础网页结构搭建、数字文旅平台内容整理与页面维护。

		section.section.result-section
			.section-heading
				span Honors & Publications
				h2 荣誉证书与期刊
			.result-grid
				.result-card
					h3 荣誉证书
					p 普通话二级甲等、大学英语六级、演出经纪人证书、全国大学生广告艺术大赛策划案三等奖、研究生绩点专业前 10%、本科绩点专业前 10%、中共党员
				.result-card
					h3 期刊成果
					ul
						li 微短剧的共情叙事与文化认同实践——以《逃出大英博物馆》为例；第一作者；《数字出版研究》
						li 基于社交媒体的网民情感与群体认同分析——以“TI12”AR止步四强为例；第二作者；《数字出版研究》
						li 文化遗产数字化及数字文旅可视化服务技术研究；第三作者；《中国图象图形学报》

